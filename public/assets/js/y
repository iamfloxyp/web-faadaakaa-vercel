// ===============HELPER: GET CART ROW COUNT================
function getCartRowCount() {
  return document.querySelectorAll(".cart-row").length;
}
function syncHeaderFromCartUI() {
  const rows = document.querySelectorAll(".cart-row");
  const count = rows.length;

  const cartBadge = document.querySelector("#cartCount, .cart-badge");
  if (cartBadge) {
    cartBadge.textContent = count;
    cartBadge.classList.toggle("hidden", count === 0);
  }

  if (count === 0) {
    const cartAmountEl = document.querySelector("#cartTotalAmount, .cart-total");
    if (cartAmountEl) cartAmountEl.textContent = "₦0.00";
  }
}


