          <p class="text-[#101828] text-[16px] font-medium">${addr.name}</p>
          <p class="text-[#353C49] text-[14px]">${addr.mobile}</p>
          <p class="text-[#535862] text-[14px]">
            ${addr.address}, ${addr.state}
          </p>
        </div>
      </label>
      `
    );
  });
}

