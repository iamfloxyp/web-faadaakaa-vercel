// ===============UPDATE CART ITEMS================
function updateCartQuantityFromCart(productId, newQty) {
  const token = sessionStorage.getItem("AUTH_TOKEN");
  if (!token) return Promise.reject();

  const formData = new FormData();
  formData.append("product_id", productId);
  formData.append("quantity", newQty);
  formData.append("token", token);

  return fetch("https://api.faadaakaa.com/api/updatecart", {
    method: "POST",
    body: formData
  }).then(res => res.json());
}

document.addEventListener("click", function (e) {
  const btn = e.target.closest(".qty-btn");
  if (!btn) return;

  const productId = btn.dataset.productId;
  if (!productId) return;

  const rowEl = btn.closest(".cart-row");
  if (!rowEl) return;

  // ✅ get ALL qty + total elements for this product inside this row (mobile + desktop)
  const qtyEls = rowEl.querySelectorAll(`.cart-qty[data-product-id="${productId}"]`);
  const totalEls = rowEl.querySelectorAll(`.line-total[data-product-id="${productId}"]`);
  const unitPriceEl = rowEl.querySelector(`.unit-price[data-product-id="${productId}"]`);

  if (!qtyEls.length || !totalEls.length || !unitPriceEl) return;

  let currentQty = Number(qtyEls[0].textContent);
  const unitPrice = Number(unitPriceEl.dataset.unitPrice);

  if (isNaN(currentQty) || isNaN(unitPrice)) return;

  // INCREMENT
  if (btn.classList.contains("increment")) {
    currentQty += 1;
  }

  // DECREMENT
  if (btn.classList.contains("decrement")) {
    if (currentQty === 1) {
      const cartItemId = rowEl.dataset.cartId;
      if (!cartItemId) {
        toast("Cart item id missing", "error");
        return;
      }
      removeCartItem(cartItemId, rowEl);
      return;
    }
    currentQty -= 1;
  }

  // ✅ IMMEDIATE UI UPDATE (updates both mobile + desktop)
  qtyEls.forEach(el => (el.textContent = currentQty));
  totalEls.forEach(el => (el.textContent = `₦${(unitPrice * currentQty).toLocaleString()}`));

  // BACKEND SYNC
  updateCartQuantityFromCart(productId, currentQty)
    .then(result => {
      if (!result.status) {
        toast(result.message || "Failed to update cart", "error");
        return;
      }

      // ✅ refresh schedule + payment from backend
      if (typeof window.refreshCartUI === "function") {
        window.refreshCartUI();
      }
    })
    .catch(() => toast("Network error", "error"));
});

// =============== DELETE CART ITEM =================

function removeCartItem(cartItemId, rowEl) {
  const token = sessionStorage.getItem("AUTH_TOKEN");
  if (!token || !cartItemId || !rowEl) return;

  // 🔥 1. IMMEDIATE UI UPDATE (LIKE QUANTITY)
  rowEl.remove();
  syncHeaderFromCartUI();

  const remainingRows = getCartRowCount();

  if (remainingRows === 0) {
    showEmptyCartState();

    if (typeof window.renderEmptyCartState === "function") {
      window.renderEmptyCartState();
    }
  }

  toast("Item removed from cart", "success");

  // 🔁 2. BACKEND SYNC (NO UI DEPENDENCY)
  const formData = new FormData();
  formData.append("id", cartItemId);
  formData.append("token", token);
  formData.append("access_token", token);

  fetch("https://api.faadaakaa.com/api/deletecartitem", {
    method: "POST",
    body: formData
  })
    .then(res => res.json())
    .then(result => {
      if (!result.status) {
        toast(result.message || "Failed to remove item", "error");
      }

      if (typeof window.refreshCartUI === "function") {
  window.refreshCartUI(true);
}

      if (typeof window.checkIfCurrentProductInCart === "function") {
        window.checkIfCurrentProductInCart();
      }
    })
    .catch(() => {
      toast("Network error removing item", "error");
    });
}

// ==============DELETE ICON HANDLER================
document.addEventListener("click", function (e) {
  const deleteBtn = e.target.closest(".remove-cart-item");
  if (!deleteBtn) return;

  e.preventDefault();

  const cartItemId = deleteBtn.dataset.id;
  const rowEl = deleteBtn.closest(".cart-row");

  if (!cartItemId) {
    toast("Cart item id missing", "error");
    return;
